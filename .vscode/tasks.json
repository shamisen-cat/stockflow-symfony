{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "PHPStan: analyse current file",
            "type": "shell",
            "command": "vendor/bin/phpstan",
            "args": [
                "analyse",
                "-c",
                "phpstan.dist.neon",
                "--no-progress",
                "${relativeFile}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "PHPStan: analyse",
            "type": "shell",
            "command": "vendor/bin/phpstan",
            "args": [
                "analyse",
                "-c",
                "phpstan.dist.neon",
                "--memory-limit=1G"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
