{
  "compilerOptions": {
    "checkJs": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "paths": {
      "@hotwired/stimulus": ["./assets/vendor/@hotwired/stimulus/stimulus.index.js"]
    }
  },
  "include": [
    "assets/**/*.js",
    "assets/types/**/*.d.ts"
  ],
  "exclude": [
    "assets/vendor/**",
    "assets/controllers/csrf_protection_controller.js"
  ]
}
