{#
  App shell with header, sidebar, and main (extends only).

  Blocks:
  - sidebar: navigation in the aside
  - main: primary page content
#}

{% extends 'base.html.twig' %}

{% block body %}
  <body
    class="
      group/sidebar
      flex flex-col
      overflow-hidden h-dvh
      bg-slate-50
      text-slate-900 antialiased
    "
    data-controller="sidebar"
    data-sidebar-open-value="false"
    data-sidebar-open-label-value="{{ 'layout.sidebar.open'|trans }}"
    data-sidebar-close-label-value="{{ 'layout.sidebar.close'|trans }}"
  >
    <header
      class="
        relative z-20
        flex items-center shrink-0
        h-14 xl:h-12
        pr-18 xl:pr-4
        bg-white
        border-b border-slate-200
      "
    >
      <div
        class="
          flex items-center justify-between
          w-full min-w-0
        "
      >
        <a
          href="#"
          class="
            inline-flex items-center justify-center shrink-0 gap-1
            min-w-0
            min-h-11 xl:h-9
            px-4
            rounded-lg
            text-lg
            text-slate-900 hover:text-slate-700
            focus:outline-none
            focus:ring-2 focus:ring-slate-700
            transition
          "
        >
          {{ ux_icon(
            'lucide:package',
            { class: 'size-5 shrink-0' },
          ) }}
          <span>Stockflow</span>
        </a>

        <div class="flex items-center shrink-0">
          <a
            href="#"
            class="
              inline-flex items-center justify-center
              min-w-11 xl:w-9
              min-h-11 xl:h-9
              hover:bg-slate-100
              rounded-lg
              text-slate-700 hover:text-slate-900
              focus:outline-none
              focus:ring-2 focus:ring-slate-700
              transition
            "
            aria-label="{{ 'layout.user_settings'|trans }}"
          >
            {{ ux_icon(
              'lucide:circle-user',
              { class: 'size-6 shrink-0' },
            ) }}
          </a>
        </div>
      </div>
    </header>

    <button
      type="button"
      class="
        group/toggle
        fixed top-1.5 right-4 z-50
        inline-flex items-center justify-center
        w-11 h-11
        bg-transparent hover:bg-slate-100
        rounded-lg
        focus:outline-none
        focus:ring-2 focus:ring-slate-700
        transition
        xl:hidden
      "
      data-sidebar-target="toggle"
      data-action="click->sidebar#toggle"
      aria-controls="app-sidebar"
      aria-label="{{ 'layout.sidebar.open'|trans }}"
      aria-expanded="false"
    >
      <span class="relative block w-6 h-6">
        <span
          class="
            absolute top-0 left-0
            block w-6 h-0.5
            bg-slate-900
            origin-center
            group-aria-expanded/toggle:top-1/2
            group-aria-expanded/toggle:-translate-y-1/2
            group-aria-expanded/toggle:rotate-45
            transition-all duration-300
          "
        ></span>
        <span
          class="
            absolute top-2.5 left-0
            block w-6 h-0.5
            bg-slate-900
            origin-center
            group-aria-expanded/toggle:top-1/2
            group-aria-expanded/toggle:-translate-y-1/2
            group-aria-expanded/toggle:opacity-0
            transition-all duration-300
          "
        ></span>
        <span
          class="
            absolute top-5 left-0
            block w-6 h-0.5
            bg-slate-900
            origin-center
            group-aria-expanded/toggle:top-1/2
            group-aria-expanded/toggle:-translate-y-1/2
            group-aria-expanded/toggle:-rotate-45
            transition-all duration-300
          "
        ></span>
      </span>
    </button>

    <div class="flex flex-1 min-w-0 min-h-0">
      <aside
        id="app-sidebar"
        class="
          fixed inset-y-0 right-0
          z-40 xl:z-auto
          flex flex-col
          xl:shrink-0
          w-64 xl:w-56
          min-h-0
          bg-white
          border-l xl:border-l-0
          xl:border-r
          border-slate-200
          shadow-xl xl:shadow-none
          translate-x-full xl:translate-x-0
          max-xl:group-data-[sidebar-open-value=true]/sidebar:translate-x-0
          transition-transform duration-300
          xl:static
        "
        data-sidebar-target="sidebar"
        aria-hidden="true"
      >
        <div
          class="
            flex items-center shrink-0
            h-14
            pl-4 pr-16
            border-b border-slate-200
            xl:hidden
          "
        >
          <span class="text-sm">
            {{ 'layout.menu'|trans }}
          </span>
        </div>

        <nav class="flex-1 overflow-y-auto min-h-0">
          {% block sidebar %}{% endblock %}
        </nav>

        <div class="shrink-0 pb-[max(0.75rem,env(safe-area-inset-bottom))]">
          <form
            method="post"
            action="{{ logout_path() }}"
          >
            <input
              type="hidden"
              name="_csrf_token"
              value="{{ csrf_token('logout') }}"
            >
            <button
              type="submit"
              class="
                inline-flex items-center gap-2
                w-full min-h-11
                pl-4
                hover:bg-slate-100
                text-sm
                text-slate-700 hover:text-slate-900
                focus:outline-none
                focus:ring-2 focus:ring-inset focus:ring-slate-700
                transition
              "
              aria-label="{{ 'layout.logout'|trans }}"
            >
              {{ ux_icon(
                'lucide:log-out',
                { class: 'size-4 shrink-0' },
              ) }}
              <span>{{ 'layout.logout'|trans }}</span>
            </button>
          </form>
        </div>
      </aside>

      <main
        class="
          flex flex-col flex-1 overflow-hidden
          min-w-0 min-h-0
        "
      >
        {% block main %}{% endblock %}
      </main>
    </div>

    <div
      class="
        fixed inset-0 z-30
        bg-slate-900/50
        opacity-0
        pointer-events-none
        max-xl:group-data-[sidebar-open-value=true]/sidebar:opacity-100
        max-xl:group-data-[sidebar-open-value=true]/sidebar:pointer-events-auto
        transition-opacity duration-300
        xl:hidden
      "
      data-sidebar-target="overlay"
      data-action="click->sidebar#close"
    ></div>
  </body>
{% endblock %}
