{#
  App shell with header, sidebar, and main (extends only).

  Blocks:
  - sidebar: navigation in the aside
  - main: primary page content
#}
{% extends 'base.html.twig' %}

{% block body %}
  <body
    data-controller="sidebar"
    data-sidebar-open-value="false"
    data-sidebar-open-label-value="{{ 'layout.sidebar.open'|trans }}"
    data-sidebar-close-label-value="{{ 'layout.sidebar.close'|trans }}"
    class="
      group/sidebar
      flex flex-col h-dvh overflow-hidden bg-slate-50 text-slate-900 antialiased
    "
  >
    <header
      class="
        relative z-20
        flex items-center h-14 shrink-0 pl-4 pr-20 bg-white border-b border-slate-200
        xl:h-12 xl:pr-4
      "
    >
      <div class="flex items-center justify-between w-full min-w-0 gap-4">
        <a
          href="{{ path('app_dev_users') }}"
          class="
            inline-flex items-center min-w-0 gap-1 text-lg font-semibold text-slate-900
            hover:text-slate-700
          "
        >
          {{ ux_icon('lucide:package', { class: 'size-5 shrink-0' }) }}
          <span class="truncate">Stockflow</span>
        </a>

        <div class="flex items-center shrink-0 gap-2">
          <form method="post" action="{{ logout_path() }}" class="inline-flex">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
            <button
              type="submit"
              class="
                inline-flex flex-col items-center justify-center min-w-11 min-h-11 gap-0.5 px-1 py-1
                rounded-lg text-xs font-medium text-slate-700 transition
                hover:bg-slate-100 hover:text-slate-900
                focus:outline-none focus:ring-2 focus:ring-slate-900
                xl:flex-row xl:w-auto xl:min-h-0 xl:h-9 xl:gap-1.5 xl:px-3 xl:py-0 xl:text-sm
              "
              aria-label="{{ 'layout.logout'|trans }}"
            >
              {{ ux_icon('lucide:log-out', { class: 'size-5 shrink-0 xl:size-4' }) }}
              <span class="text-[10px] leading-tight xl:text-sm">{{ 'layout.logout'|trans }}</span>
            </button>
          </form>
        </div>
      </div>
    </header>

    <button
      type="button"
      data-sidebar-target="toggle"
      data-action="click->sidebar#toggle"
      class="
        group/toggle
        fixed top-1.5 right-2.5 z-50
        inline-flex items-center justify-center w-11 h-11
        bg-transparent rounded-lg text-slate-900 transition
        hover:bg-slate-50
        focus:outline-none focus:ring-2 focus:ring-slate-900
        xl:hidden
      "
      aria-controls="app-sidebar"
      aria-expanded="false"
      aria-label="{{ 'layout.sidebar.open'|trans }}"
    >
      <span class="relative block w-6 h-6">
        <span
          class="
            absolute top-0 left-0
            block w-6 h-0.5 bg-slate-900 origin-center transition-all duration-300
            group-aria-expanded/toggle:top-1/2 group-aria-expanded/toggle:-translate-y-1/2
            group-aria-expanded/toggle:rotate-45
          "
        ></span>
        <span
          class="
            absolute top-2.5 left-0
            block w-6 h-0.5 bg-slate-900 origin-center transition-all duration-300
            group-aria-expanded/toggle:top-1/2 group-aria-expanded/toggle:-translate-y-1/2
            group-aria-expanded/toggle:opacity-0
          "
        ></span>
        <span
          class="
            absolute top-5 left-0
            block w-6 h-0.5 bg-slate-900 origin-center transition-all duration-300
            group-aria-expanded/toggle:top-1/2 group-aria-expanded/toggle:-translate-y-1/2
            group-aria-expanded/toggle:-rotate-45
          "
        ></span>
      </span>
    </button>

    <div class="flex flex-1 min-w-0 min-h-0">
      <aside
        id="app-sidebar"
        data-sidebar-target="sidebar"
        class="
          fixed inset-y-0 right-0 z-40 translate-x-full
          flex flex-col w-64 min-h-0 bg-white border-l border-slate-200 shadow-xl
          transition-transform duration-300
          max-xl:group-data-[sidebar-open-value=true]/sidebar:translate-x-0
          xl:static xl:z-auto xl:translate-x-0 xl:shrink-0 xl:border-l-0 xl:border-r xl:shadow-none
        "
        aria-hidden="true"
      >
        <div class="flex items-center h-14 shrink-0 pl-4 pr-16 border-b border-slate-200 xl:hidden">
          <span class="text-sm font-semibold text-slate-900">{{ 'layout.menu'|trans }}</span>
        </div>

        <nav class="flex-1 min-h-0 overflow-y-auto px-2 py-4 xl:pt-3">
          {% block sidebar %}{% endblock %}
        </nav>
      </aside>

      <main class="flex flex-col flex-1 min-w-0 min-h-0 overflow-hidden">
        {% block main %}{% endblock %}
      </main>
    </div>

    <div
      data-sidebar-target="overlay"
      data-action="click->sidebar#close"
      class="
        fixed inset-0 z-30
        bg-slate-900/50 opacity-0 transition-opacity duration-300 pointer-events-none
        max-xl:group-data-[sidebar-open-value=true]/sidebar:opacity-100
        max-xl:group-data-[sidebar-open-value=true]/sidebar:pointer-events-auto
        xl:hidden
      "
    ></div>
  </body>
{% endblock %}
