{#
  List page layout for two_column main (embed only).

  Blocks:
  - list_header: page heading (padded by layout)
  - list_filters: search and filter controls (optional)
  - list_body: data presentation (usually list_table embed)
  - list_footer: list navigation (usually pagination include)
#}

<div class="flex flex-col flex-1 min-h-0 pt-2">
  {% include 'components/flash_messages.html.twig' %}

  <header class="shrink-0 px-4 pb-2">
    {% block list_header %}{% endblock %}
  </header>

  {% block list_filters %}{% endblock %}

  <section
    class="
      flex flex-col flex-1 min-h-0
      border-y border-slate-200
    "
  >
    <div
      class="
        flex flex-col flex-1 min-h-0
        bg-white
      "
    >
      {% block list_body %}{% endblock %}
    </div>

    <footer class="shrink-0 pb-[max(0.75rem,env(safe-area-inset-bottom))]">
      {% block list_footer %}{% endblock %}
    </footer>
  </section>
</div>
