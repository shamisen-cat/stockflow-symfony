{#
  Sortable table header cell.

  Required variables (include ... with):
  - label: Column header text
  - sortKey: Key for the ?sort= query parameter (must match sortMap in the controller)
  - currentKey: Currently active sort key (from the controller)
  - currentDirection: 'asc' or 'desc' (from the controller)
#}

{% if currentKey == sortKey %}
  {% set ariaSort = currentDirection == 'asc' ? 'ascending' : 'descending' %}
  {% set nextDirection = currentDirection == 'asc' ? 'desc' : 'asc' %}
{% else %}
  {% set ariaSort = 'none' %}
  {% set nextDirection = 'asc' %}
{% endif %}

<th
  scope="col"
  class="
    sticky top-0 z-10
    px-4 py-2.5
    bg-slate-50
    border-b border-slate-200
    whitespace-nowrap
  "
  aria-sort="{{ ariaSort }}"
>
  <a
    href="{{ path(
      app.request.attributes.get('_route'),
      app.request.query.all|merge({
        sort: sortKey,
        direction: nextDirection,
        page: 1,
      }),
    ) }}"
    class="
      inline-flex items-center gap-1
      rounded
      text-slate-700 hover:text-slate-900
      focus:outline-none
      focus:ring-2 focus:ring-offset-2 focus:ring-slate-700
      transition
    "
  >
    {{ label }}

    {% if currentKey == sortKey %}
      <span
        class="text-slate-400"
        aria-hidden="true"
      >
        {{ currentDirection == 'asc' ? '↑' : '↓' }}
      </span>
    {% endif %}
  </a>
</th>
