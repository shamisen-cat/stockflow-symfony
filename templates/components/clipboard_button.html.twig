{#
  Icon button that copies text via the clipboard Stimulus controller.

  Excluded from the tab order by default (secondary utility action).

  Required variables (include ... with):
  - text: string written to the clipboard
  - copyLabel: title / aria-label before copy
  - copiedLabel: title / aria-label after a successful copy
#}

<button
  type="button"
  class="
    inline-flex items-center justify-center shrink-0
    w-6 h-6
    hover:bg-slate-200
    rounded
    text-slate-700 hover:text-slate-900
    focus:outline-none
    transition
  "
  title="{{ copyLabel }}"
  tabindex="-1"
  data-controller="clipboard"
  data-clipboard-text-value="{{ text }}"
  data-clipboard-copy-label-value="{{ copyLabel }}"
  data-clipboard-copied-label-value="{{ copiedLabel }}"
  data-action="click->clipboard#copy"
  aria-label="{{ copyLabel }}"
>
  <span data-clipboard-target="copyIcon">
    {{ ux_icon(
      'lucide:copy',
      { class: 'size-3.5 shrink-0' },
    ) }}
  </span>

  <span
    class="hidden"
    data-clipboard-target="checkIcon"
  >
    {{ ux_icon(
      'lucide:check',
      { class: 'size-3.5 shrink-0' },
    ) }}
  </span>
</button>
