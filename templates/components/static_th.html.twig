{#
  Static table header cell.

  Required variables (include ... with):
  - label: Column header text
#}
<th
  scope="col"
  class="
    sticky top-0 z-10 px-4 py-3 bg-slate-50 border-b border-slate-200
    font-semibold text-slate-700 whitespace-nowrap
    sm:px-6 lg:py-2
  "
>
  {{ label }}
</th>
