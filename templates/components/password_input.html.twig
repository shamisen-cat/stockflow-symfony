{#
  Password input with show/hide toggle (password-visibility Stimulus).

  Required variables (include ... with):
  - id: input id (also used for label for= and aria-controls)
  - name: input name
  - label: visible label text
  - showLabel: toggle title/aria when password is hidden
  - hideLabel: toggle title/aria when password is visible

  Optional:
  - value: defaults to empty
  - placeholder: omitted when empty
  - autocomplete: defaults to current-password
  - required: defaults to true
  - autofocus: defaults to false
  - invalid: defaults to false (red border + aria-invalid)
#}

{% set value = value|default('') %}
{% set placeholder = placeholder|default('') %}
{% set autocomplete = autocomplete|default('current-password') %}
{% set required = required|default(true) %}
{% set autofocus = autofocus|default(false) %}
{% set invalid = invalid|default(false) %}

<div>
  <label
    for="{{ id }}"
    class="
      block mb-1 pl-1
      text-sm text-slate-700
    "
  >
    {{ label }}
  </label>
  <div
    class="flex items-stretch"
    data-controller="password-visibility"
    data-password-visibility-show-label-value="{{ showLabel }}"
    data-password-visibility-hide-label-value="{{ hideLabel }}"
  >
    <input
      type="password"
      id="{{ id }}"
      name="{{ name }}"
      value="{{ value }}"

      {% if placeholder != '' %}
        placeholder="{{ placeholder }}"
      {% endif %}

      autocomplete="{{ autocomplete }}"

      {% if required %}
        required
      {% endif %}

      {% if autofocus %}
        autofocus
      {% endif %}

      class="
        relative
        z-0 focus:z-10
        flex-1
        px-4 min-w-0
        py-2
        bg-white
        border
        {{ invalid
          ? 'border-red-400 focus:border-red-700'
          : 'border-slate-200 focus:border-slate-700'
        }}
        rounded-l-lg shadow-sm
        text-sm
        placeholder:text-slate-400
        focus:outline-none
        focus:ring-2 focus:ring-slate-700
        transition
      "
      data-password-visibility-target="input"
      aria-invalid="{{ invalid ? 'true' : 'false' }}"
    >
    <button
      type="button"
      class="
        group/toggle
        relative
        z-0 focus:z-10
        inline-flex items-center justify-center -ml-px
        w-10
        bg-slate-100 hover:bg-slate-200
        border
        border-slate-200 focus:border-slate-700
        rounded-r-lg shadow-sm
        text-slate-500 hover:text-slate-700
        select-none
        focus:outline-none
        focus:ring-2 focus:ring-slate-700
        transition
      "
      title="{{ showLabel }}"
      data-password-visibility-target="toggle"
      data-action="click->password-visibility#toggle"
      aria-label="{{ showLabel }}"
      aria-controls="{{ id }}"
      aria-pressed="false"
    >
      <span class="group-aria-pressed/toggle:hidden">
        {{ ux_icon(
          'lucide:eye',
          { class: 'size-4 shrink-0' },
        ) }}
      </span>
      <span class="hidden group-aria-pressed/toggle:block">
        {{ ux_icon(
          'lucide:eye-off',
          { class: 'size-4 shrink-0' },
        ) }}
      </span>
    </button>
  </div>
</div>
