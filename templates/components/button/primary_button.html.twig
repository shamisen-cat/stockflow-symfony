{#
  Primary action button (blue filled).

  Required variables (include ... with):
  - label: visible button text

  Optional:
  - type: defaults to submit
  - fullWidth: defaults to false (adds w-full when true)
#}

{% set type = type|default('submit') %}
{% set fullWidth = fullWidth|default(false) %}

<button
  type="{{ type }}"
  class="
    inline-flex items-center justify-center
    {{ fullWidth ? 'w-full' : '' }}
    px-4 py-2
    bg-blue-600 hover:bg-blue-700
    rounded-lg shadow-sm
    text-sm text-white
    focus:outline-none
    focus:ring-2 focus:ring-slate-700
    transition
  "
>
  {{ label }}
</button>
