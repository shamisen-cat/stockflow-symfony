{#
  Square icon link button (header actions, etc.).

  Required variables (include ... with):
  - href: link destination
  - label: title / aria-label text
  - icon: UX Iconify name (e.g. lucide:plus)
#}

<a
  href="{{ href }}"
  class="
    inline-flex items-center justify-center
    w-11 h-11
    bg-white hover:bg-slate-100
    border border-slate-200
    rounded-lg shadow-sm
    text-slate-700 hover:text-slate-900
    focus:outline-none
    focus:ring-2 focus:ring-slate-700
    transition
  "
  title="{{ label }}"
  aria-label="{{ label }}"
>
  {{ ux_icon(
    icon,
    { class: 'size-5 shrink-0' },
  ) }}
</a>
