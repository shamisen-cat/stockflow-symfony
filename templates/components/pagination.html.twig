{#
  Pagination navigation for server-side paginated lists.

  Required variables (include ... with):
  - pagination: Pagerfanta instance (from the controller)
#}
{% if pagination.nbResults > 0 %}
  {% set btnBase = 'inline-flex items-center px-3 py-1.5 border rounded-lg text-sm font-medium' %}
  {% set btnEnabled = btnBase
    ~ ' bg-white border-slate-200 text-slate-700 transition'
    ~ ' hover:bg-slate-50'
    ~ ' focus:outline-none focus:ring-2 focus:ring-slate-900 focus:ring-offset-2'
  %}
  {% set btnDisabled = btnBase
    ~ ' bg-white border-slate-200 text-slate-400 opacity-50 cursor-not-allowed'
  %}

  <nav
    class="
      flex flex-col gap-3 px-4 py-3 border-t border-slate-200
      sm:flex-row sm:items-center sm:px-6
    "
    aria-label="Pagination"
  >
    <div class="flex gap-4">
      {% if pagination.hasPreviousPage %}
        <a
          href="{{ path(
            app.request.attributes.get('_route'),
            app.request.query.all|merge({ page: pagination.previousPage }),
          ) }}"
          class="{{ btnEnabled }}"
        >
          {{ 'pagination.previous'|trans }}
        </a>
      {% else %}
        <span class="{{ btnDisabled }}" aria-disabled="true">
          {{ 'pagination.previous'|trans }}
        </span>
      {% endif %}

      {% if pagination.hasNextPage %}
        <a
          href="{{ path(
            app.request.attributes.get('_route'),
            app.request.query.all|merge({ page: pagination.nextPage }),
          ) }}"
          class="{{ btnEnabled }}"
        >
          {{ 'pagination.next'|trans }}
        </a>
      {% else %}
        <span class="{{ btnDisabled }}" aria-disabled="true">
          {{ 'pagination.next'|trans }}
        </span>
      {% endif %}
    </div>

    <p class="text-sm text-slate-600 sm:ml-auto">
      {{ 'pagination.summary'|trans({
        '%start%': pagination.currentPageOffsetStart,
        '%end%': pagination.currentPageOffsetEnd,
        '%total%': pagination.nbResults,
      }) }}
    </p>
  </nav>
{% endif %}
