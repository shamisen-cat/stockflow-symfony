{#
  Dev user new form.

  Required variables (include from parent):
  - email: string value for the email input
  - error: string|null error code for field highlighting (e.g. email.invalid_format)
#}

{% set emailHasError = false %}
{% set passwordHasError = false %}

{% if error is not null %}
  {% set emailHasError = error starts with 'email.' or error == 'user.already_exists' %}
  {% set passwordHasError = error starts with 'password.' %}
{% endif %}

<form
  method="post"
  action="{{ path('app_dev_users_new') }}"
  novalidate
  class="w-full max-w-lg"
>
  <div class="mb-4">
    <label
      for="email"
      class="
        block mb-1 pl-1
        text-sm text-slate-700
      "
    >
      {{ 'dev.user.create.email_label'|trans }}
    </label>
    <input
      type="email"
      id="email"
      name="email"
      value="{{ email }}"
      placeholder="{{ 'dev.user.create.email_placeholder'|trans }}"
      autocomplete="off"
      autofocus
      class="
        block w-full
        px-4 py-2
        bg-white
        border
        {{ emailHasError
          ? 'border-red-400 focus:border-red-700'
          : 'border-slate-200 focus:border-slate-700'
        }}
        rounded-lg shadow-sm
        text-sm
        placeholder:text-slate-400
        focus:outline-none
        focus:ring-2 focus:ring-slate-700
        transition
      "
      aria-invalid="{{ emailHasError ? 'true' : 'false' }}"
    >
  </div>

  <div class="mb-8">
    <label
      for="password"
      class="
        block mb-1 pl-1
        text-sm text-slate-700
      "
    >
      {{ 'dev.user.create.password_label'|trans }}
    </label>
    <input
      type="password"
      id="password"
      name="password"
      placeholder="{{ 'dev.user.create.password_placeholder'|trans }}"
      autocomplete="new-password"
      class="
        block w-full
        px-4 py-2
        bg-white
        border
        {{ passwordHasError
          ? 'border-red-400 focus:border-red-700'
          : 'border-slate-200 focus:border-slate-700'
        }}
        rounded-lg shadow-sm
        text-sm
        placeholder:text-slate-400
        focus:outline-none
        focus:ring-2 focus:ring-slate-700
        transition
      "
      aria-invalid="{{ passwordHasError ? 'true' : 'false' }}"
    >
  </div>

  <input
    type="hidden"
    name="_token"
    value="{{ csrf_token('dev_user_create') }}"
  >
  <button
    type="submit"
    class="
      inline-flex items-center justify-center w-full
      px-4 py-2
      bg-blue-600 hover:bg-blue-700
      rounded-lg shadow-sm
      text-sm text-white
      focus:outline-none
      focus:ring-2 focus:ring-slate-700
      transition
    "
  >
    {{ 'dev.user.create.submit'|trans }}
  </button>
</form>
