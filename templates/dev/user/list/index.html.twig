{#
  Dev user list page (UserDevController::index).

  Variables from the controller:
  - users: User[] current page results
  - pagination: Pagerfanta instance
  - currentKey: active sort key (id, email, created_at, updated_at)
  - currentDirection: 'asc' or 'desc'
  - searchEmail: current email search query (empty string when unset)
  - sidebarLinks: DevSidebarLink[] parent sidebar navigation links
  - sidebarSubLinks: DevSidebarLink[] sub links for the current section
  - currentLink: DevSidebarLinkId active parent sidebar link id
#}

{% extends 'layout/two_column.html.twig' %}

{% block title %}{{ 'dev.user.title'|trans }}{% endblock %}

{% block sidebar %}
  {% include 'components/sidebar.html.twig' with {
    sidebarLinks: sidebarLinks,
    sidebarSubLinks: sidebarSubLinks,
    currentLink: currentLink,
  } only %}
{% endblock %}

{% block main %}
  {% embed 'layout/list_page.html.twig' %}
    {% block list_header %}
      {% include 'dev/user/list/_header.html.twig' only %}
    {% endblock %}

    {% block list_filters %}
      {% include 'dev/user/list/_search_form.html.twig' with {
        searchEmail: searchEmail,
      } only %}
    {% endblock %}

    {% block list_body %}
      {% embed 'components/list/list_table.html.twig' %}
        {% block table_head %}
          {% include 'dev/user/list/_table_head.html.twig' with {
            currentKey: currentKey,
            currentDirection: currentDirection,
          } only %}
        {% endblock %}

        {% block table_body %}
          {% include 'dev/user/list/_table_body.html.twig' with {
            users: users,
          } only %}
        {% endblock %}
      {% endembed %}
    {% endblock %}

    {% block list_footer %}
      {% include 'components/list/pagination.html.twig' with {
        pagination: pagination,
      } only %}
    {% endblock %}
  {% endembed %}
{% endblock %}
