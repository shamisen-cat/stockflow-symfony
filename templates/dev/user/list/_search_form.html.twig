{#
  Dev user list email search form.

  Required variables (include from parent):
  - searchEmail: current email query value
#}

<form
  method="get"
  action="{{ path('app_dev_users') }}"
  class="px-4 pb-4"
>
  <div class="flex flex-row items-end gap-4">
    <div class="w-full min-w-0 max-w-lg">
      {% include 'components/form/text_input.html.twig' with {
        type: 'search',
        id: 'search-email',
        name: 'email',
        label: 'dev.user.search.email_label'|trans,
        value: searchEmail,
        placeholder: 'dev.user.search.email_placeholder'|trans,
        autocomplete: 'off',
      } only %}
    </div>

    <div class="flex gap-4 shrink-0">
      {% include 'components/primary_button.html.twig' with {
        label: 'dev.user.search.submit'|trans,
      } only %}

      {% if searchEmail %}
        <a
          href="{{ path('app_dev_users') }}"
          class="
            inline-flex items-center justify-center
            px-4 py-2
            bg-white hover:bg-slate-100
            border border-slate-200
            rounded-lg shadow-sm
            text-sm text-slate-700
            focus:outline-none
            focus:ring-2 focus:ring-slate-700
            transition
          "
        >
          {{ 'dev.user.search.clear'|trans }}
        </a>
      {% endif %}
    </div>
  </div>

  <details class="group mt-3">
    <summary
      class="
        inline-flex items-center gap-1
        rounded
        text-sm
        text-slate-700 hover:text-slate-900
        cursor-pointer select-none
        focus:outline-none
        focus:ring-2 focus:ring-offset-2 focus:ring-slate-700
        transition
      "
    >
      {{ 'dev.user.search.details'|trans }}
    </summary>

    <div class="pt-3"></div>
  </details>
</form>
