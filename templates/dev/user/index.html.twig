{% extends 'base.html.twig' %}

{% block title %}Stockflow | Users - dev{% endblock %}

{% block body %}
  <main>
    <h1>Users</h1>

    <form
      method="post"
      action="{{ path('app_dev_users_create') }}"
    >
      <input
        type="hidden"
        name="_token"
        value="{{ csrf_token('dev_user_create') }}"
      >
      <button type="submit">Create dev user</button>
    </form>

    <table>
      <thead>
        <tr>
          <th scope="col">id</th>
          <th scope="col">email</th>
          <th scope="col">deleted_at</th>
          <th scope="col">actions</th>
        </tr>
      </thead>
      <tbody>
        {% for user in users %}
          <tr>
            <td><code>{{ user.id.toRfc4122() }}</code></td>
            <td>{{ user.email }}</td>
            <td>
              {% if user.deletedAt %}
                <time datetime="{{ user.deletedAt|date('c') }}">{{ user.deletedAt|date('Y-m-d H:i:s') }}</time>
              {% else %}
                —
              {% endif %}
            </td>
            <td>
              {% if not user.isDeleted %}
                <form
                  method="post"
                  action="{{ path('app_dev_users_delete', { id: user.id.toRfc4122() }) }}"
                >
                  <input
                    type="hidden"
                    name="_token"
                    value="{{ csrf_token('dev_user_delete') }}"
                  >
                  <button type="submit">Delete</button>
                </form>
              {% endif %}
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="4">No users yet.</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </main>
{% endblock %}
