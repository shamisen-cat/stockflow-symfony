{% extends 'dev/layout.html.twig' %}

{% block title %}Stockflow | ユーザー管理 - DevTools{% endblock %}

{% block main_body %}
  <div class="max-w-6xl mx-auto px-4 pt-3 pb-8 sm:px-6 lg:px-8">
    <header class="flex flex-col gap-4 mb-8 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-medium text-amber-700">
          DevTools
        </p>
        <h1 class="mt-1 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">
          ユーザー管理
        </h1>
        <p class="mt-2 text-sm text-slate-600">
          ユーザー一覧・新規作成・編集・削除
        </p>
      </div>
      <form method="post" action="{{ path('app_dev_users_create') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('dev_user_create') }}">
        <button
          type="submit"
          class="
            inline-flex items-center justify-center w-full px-4 py-2.5
            text-sm font-semibold text-white bg-slate-900 rounded-lg shadow-sm transition
            hover:bg-slate-800
            focus:outline-none focus:ring-2 focus:ring-slate-900 focus:ring-offset-2
            sm:w-auto
          "
        >
          新規作成
        </button>
      </form>
    </header>

    <section class="overflow-hidden bg-white border border-slate-200 rounded-xl shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
          <thead class="bg-slate-50">
            <tr>
              <th
                scope="col"
                class="px-4 py-3 font-semibold text-slate-700 whitespace-nowrap sm:px-6 lg:py-2"
              >
                ID
              </th>
              <th
                scope="col"
                class="px-4 py-3 font-semibold text-slate-700 whitespace-nowrap sm:px-6 lg:py-2"
              >
                メールアドレス
              </th>
              <th
                scope="col"
                class="px-4 py-3 font-semibold text-slate-700 whitespace-nowrap sm:px-6 lg:py-2"
              >
                削除日時
              </th>
              <th
                scope="col"
                class="px-4 py-3 font-semibold text-slate-700 whitespace-nowrap sm:px-6 lg:py-2"
              >
                操作
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {% for user in users %}
              <tr class="hover:bg-slate-50">
                <td class="px-4 py-4 sm:px-6 lg:py-2.5">
                  <code
                    class="block text-xs font-mono text-slate-600"
                    title="{{ user.id.toRfc4122() }}"
                  >
                    {{- user.id.toRfc4122()|slice(0, 8) -}}…
                  </code>
                </td>
                <td class="px-4 py-4 sm:px-6 lg:py-2.5">
                  <span
                    class="
                      block max-w-xs truncate
                      {% if user.isDeleted %}
                        text-slate-500 line-through
                      {% else %}
                        font-medium text-slate-900
                      {% endif %}
                    "
                    title="{{ user.email }}"
                  >
                    {{ user.email }}
                  </span>
                </td>
                <td class="px-4 py-4 text-xs text-slate-600 whitespace-nowrap sm:px-6 lg:py-2.5">
                  {% if user.deletedAt %}
                    <time datetime="{{ user.deletedAt|date('c') }}">
                      {{ user.deletedAt|date('Y-m-d H:i:s') }}
                    </time>
                  {% else %}
                    <span class="text-slate-400">—</span>
                  {% endif %}
                </td>
                <td class="px-4 py-4 sm:px-6 lg:py-2.5">
                  {% if not user.isDeleted %}
                    <form
                      method="post"
                      action="{{ path('app_dev_users_delete', { id: user.id.toRfc4122() }) }}"
                    >
                      <input
                        type="hidden"
                        name="_token" value="{{ csrf_token('dev_user_delete') }}"
                      >
                      <button
                        type="submit"
                        class="
                          inline-flex items-center px-3 py-1.5
                          text-xs font-medium text-red-700 whitespace-nowrap
                          bg-white border border-red-200 rounded-lg transition
                          hover:bg-red-50
                          focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2
                        "
                      >
                        削除
                      </button>
                    </form>
                  {% else %}
                    <form
                      method="post"
                      action="{{ path('app_dev_users_purge', { id: user.id.toRfc4122() }) }}"
                    >
                      <input
                        type="hidden"
                        name="_token"
                        value="{{ csrf_token('dev_user_purge') }}"
                      >
                      <button
                        type="submit"
                        class="
                          inline-flex items-center px-3 py-1.5
                          text-xs font-medium text-red-900 whitespace-nowrap
                          bg-red-50 border border-red-300 rounded-lg transition
                          hover:bg-red-100
                          focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2
                        "
                      >
                        物理削除
                      </button>
                    </form>
                  {% endif %}
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="4" class="px-4 py-12 text-center text-slate-500 sm:px-6">
                  登録されているユーザーがありません。「新規作成」からユーザーを追加できます。
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
  </div>
{% endblock %}
