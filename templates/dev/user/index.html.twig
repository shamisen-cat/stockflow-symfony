{% extends 'layout/two_column.html.twig' %}

{% block title %}Stockflow | ユーザー管理 - DevTools{% endblock %}

{% block sidebar %}
  <ul class="space-y-1">
    <li>
      <a
        href="{{ path('app_dev_users') }}"
        class="block px-3 py-2 bg-slate-100 rounded-lg text-sm font-medium text-slate-900"
      >
        ユーザー管理
      </a>
    </li>
  </ul>
{% endblock %}

{% block main %}
  {% embed 'layout/list_page.html.twig' %}
    {% block list_header %}
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">
            ユーザー管理
          </h1>
          <p class="mt-2 text-sm text-slate-600">
            ユーザー一覧・新規作成・編集・削除
          </p>
        </div>

        <form method="post" action="{{ path('app_dev_users_create') }}">
          <input type="hidden" name="_token" value="{{ csrf_token('dev_user_create') }}">
          <button
            type="submit"
            class="
              inline-flex items-center justify-center w-full px-4 py-2.5
              bg-slate-900 rounded-lg shadow-sm text-sm font-semibold text-white transition
              hover:bg-slate-800
              focus:outline-none focus:ring-2 focus:ring-slate-900 focus:ring-offset-2
              sm:w-auto
            "
          >
            新規作成
          </button>
        </form>
      </div>
    {% endblock %}

    {% block list_body %}
      {% embed 'components/list_table.html.twig' %}
        {% block table_head %}
          {% include 'components/sortable_th.html.twig' with {
            label: 'ID',
            sortKey: 'id',
            currentKey: currentKey,
            currentDirection: currentDirection,
          } only %}

          {% include 'components/sortable_th.html.twig' with {
            label: 'メールアドレス',
            sortKey: 'email',
            currentKey: currentKey,
            currentDirection: currentDirection,
          } only %}

          {% include 'components/sortable_th.html.twig' with {
            label: '作成日時',
            sortKey: 'created_at',
            currentKey: currentKey,
            currentDirection: currentDirection,
          } only %}

          {% include 'components/sortable_th.html.twig' with {
            label: '更新日時',
            sortKey: 'updated_at',
            currentKey: currentKey,
            currentDirection: currentDirection,
          } only %}

          {% include 'components/static_th.html.twig' with { label: '操作' } only %}
        {% endblock %}

        {% block table_body %}
          {% for user in users %}
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-4 sm:px-6 lg:py-2.5">
                <code
                  title="{{ user.id.toRfc4122() }}"
                  class="block font-mono text-xs text-slate-600"
                >
                  {{ user.id.toRfc4122()|slice(0, 12) }}…
                </code>
              </td>

              <td class="px-4 py-4 sm:px-6 lg:py-2.5">
                <span
                  title="{{ user.email }}"
                  class="
                    block max-w-xs truncate
                    {% if user.isDeleted %}
                      line-through text-slate-500
                    {% else %}
                      font-medium text-slate-900
                    {% endif %}
                  "
                >
                  {{ user.email }}
                </span>
              </td>

              <td class="px-4 py-4 text-xs text-slate-600 whitespace-nowrap sm:px-6 lg:py-2.5">
                <time datetime="{{ user.createdAt|date('c') }}">
                  {{ user.createdAt|date('Y-m-d H:i:s') }}
                </time>
              </td>

              <td class="px-4 py-4 text-xs text-slate-600 whitespace-nowrap sm:px-6 lg:py-2.5">
                <time datetime="{{ user.updatedAt|date('c') }}">
                  {{ user.updatedAt|date('Y-m-d H:i:s') }}
                </time>
              </td>

              <td class="px-4 py-4 sm:px-6 lg:py-2.5">
                {% if not user.isDeleted %}
                  <form
                    method="post"
                    action="{{ path(
                      'app_dev_users_delete',
                      { id: user.id.toRfc4122() },
                    ) }}"
                  >
                    <input type="hidden" name="_token" value="{{ csrf_token('dev_user_delete') }}">
                    <button
                      type="submit"
                      class="
                        inline-flex items-center px-3 py-1.5
                        bg-white border border-red-200 rounded-lg
                        text-xs font-medium text-red-700 whitespace-nowrap transition
                        hover:bg-slate-50
                        focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2
                      "
                    >
                      削除
                    </button>
                  </form>
                {% else %}
                  <form
                    method="post"
                    action="{{ path(
                      'app_dev_users_purge',
                      { id: user.id.toRfc4122() },
                    ) }}"
                  >
                    <input type="hidden" name="_token" value="{{ csrf_token('dev_user_purge') }}">
                    <button
                      type="submit"
                      class="
                        inline-flex items-center px-3 py-1.5 bg-red-50
                        border border-red-300 rounded-lg
                        text-xs font-medium text-red-900 whitespace-nowrap transition
                        hover:bg-red-100
                        focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2
                      "
                    >
                      物理削除
                    </button>
                  </form>
                {% endif %}
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="5" class="px-4 py-12 text-center text-slate-500 sm:px-6">
                登録されているユーザーがありません。「新規作成」からユーザーを追加できます。
              </td>
            </tr>
          {% endfor %}
        {% endblock %}
      {% endembed %}
    {% endblock %}

    {% block list_footer %}
      {% include 'components/pagination.html.twig' with { pagination: pagination } only %}
    {% endblock %}
  {% endembed %}
{% endblock %}
