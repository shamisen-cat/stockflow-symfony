{% extends 'layout/centered.html.twig' %}

{% block title %}{{ 'login.title'|trans }}{% endblock %}

{% block content %}
  <section
    class="
      overflow-hidden
      w-full max-w-md
      border border-slate-200
      rounded-xl shadow-sm
    "
  >
    <header
      class="
        flex items-center
        h-10 pl-4
        bg-white
        border-b border-slate-200
      "
    >
      <div
        class="
          inline-flex items-center gap-1
          text-lg
        "
      >
        {{ ux_icon(
          'lucide:package',
          { class: 'size-5 shrink-0' },
        ) }}
        <span>Stockflow</span>
      </div>
    </header>

    <div class="px-6 pt-3 pb-8">
      <h1
        class="
          flex items-center justify-center gap-2 mb-4
          text-2xl
        "
      >
        {{ ux_icon(
          'lucide:log-in',
          { class: 'size-6 shrink-0' },
        ) }}
        <span>{{ 'login.heading'|trans }}</span>
      </h1>

      {% if error %}
        <div
          role="alert"
          class="
            flex items-center gap-1 mb-4
            px-4 py-2
            bg-red-50
            border border-red-200
            rounded-lg
            text-sm text-red-700
          "
        >
          {{ ux_icon(
            'lucide:circle-alert',
            { class: 'size-4 shrink-0' },
          ) }}
          <span class="min-w-0">
            {{ error.messageKey|trans(error.messageData, 'security') }}
          </span>
        </div>
      {% endif %}

      <form
        method="post"
        action="{{ path('app_login') }}"
      >
        <p class="mb-4 text-sm text-slate-700">
          {{ 'login.instructions'|trans }}
        </p>

        <div class="mb-4">
          <label
            for="username"
            class="
              block mb-1 pl-1
              text-sm text-slate-700
            "
          >
            {{ 'login.label.email'|trans }}
          </label>
          <input
            type="email"
            id="username"
            name="_username"
            value="{{ last_username }}"
            placeholder="{{ 'login.placeholder.email'|trans }}"
            autocomplete="username"
            required
            autofocus
            class="
              block w-full
              px-4 py-2
              bg-white
              border
              border-slate-200 focus:border-slate-700
              rounded-lg shadow-sm
              text-sm
              placeholder:text-slate-400
              focus:outline-none
              focus:ring-2 focus:ring-slate-700
              transition
            "
          >
        </div>

        <div class="mb-8">
          <label
            for="password"
            class="
              block mb-1 pl-1
              text-sm text-slate-700
            "
          >
            {{ 'login.label.password'|trans }}
          </label>
          <input
            type="password"
            id="password"
            name="_password"
            autocomplete="current-password"
            required
            class="
              block w-full
              px-4 py-2
              bg-white
              border
              border-slate-200 focus:border-slate-700
              rounded-lg shadow-sm
              text-sm
              placeholder:text-slate-400
              focus:outline-none
              focus:ring-2 focus:ring-slate-700
              transition
            "
          >
        </div>

        <input
          type="hidden"
          name="_csrf_token"
          value="{{ csrf_token('authenticate') }}"
        >
        <button
          type="submit"
          class="
            inline-flex items-center justify-center w-full
            px-4 py-2
            bg-blue-600 hover:bg-blue-700
            rounded-lg shadow-sm
            text-sm text-white
            focus:outline-none
            focus:ring-2 focus:ring-slate-700
            transition
          "
        >
          {{ 'login.button.submit'|trans }}
        </button>
      </form>
    </div>
  </section>
{% endblock %}
