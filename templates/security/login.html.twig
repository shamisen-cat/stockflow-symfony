{% extends 'layout/centered.html.twig' %}

{% block title %}{{ 'login.title'|trans }}{% endblock %}

{% block content %}
  <section
    class="w-full max-w-md overflow-hidden bg-white border border-slate-200 rounded-xl shadow-sm"
  >
    <header class="flex items-center h-12 pl-4 border-b border-slate-200">
      <div class="inline-flex items-center gap-1 text-lg font-semibold text-slate-900">
        {{ ux_icon('lucide:package', { class: 'size-5 shrink-0' }) }}
        <span>Stockflow</span>
      </div>
    </header>

    <div class="px-6 pt-3 pb-6 sm:px-8 sm:pb-8">
      <h1
        class="
          flex items-center justify-center gap-2 mb-6
          text-2xl font-bold tracking-tight text-slate-900
        "
      >
        {{ ux_icon('lucide:log-in', { class: 'size-6 shrink-0' }) }}
        <span>{{ 'login.heading'|trans }}</span>
      </h1>

      {% if error %}
        <div
          role="alert"
          class="
            flex items-center gap-2 mb-6 px-4 py-3
            bg-red-50 border border-red-200 rounded-lg text-sm text-red-800
          "
        >
          {{ ux_icon('lucide:circle-alert', { class: 'size-4 shrink-0' }) }}
          <span class="min-w-0">
            {{ error.messageKey|trans(error.messageData, 'security') }}
          </span>
        </div>
      {% endif %}

      <form method="post" action="{{ path('app_login') }}">
        <p class="text-sm text-slate-600">
          {{ 'login.instructions'|trans }}
        </p>

        <div class="mt-5">
          <label
            for="username"
            class="flex items-center gap-1.5 pl-1 text-sm font-medium text-slate-700"
          >
            {{ ux_icon('lucide:mail', { class: 'size-4 shrink-0' }) }}
            <span>{{ 'login.label.email'|trans }}</span>
          </label>
          <input
            type="email"
            id="username"
            name="_username"
            value="{{ last_username }}"
            placeholder="example@example.com"
            autocomplete="username"
            required
            autofocus
            class="
              block w-full mt-1.5 px-3 py-2.5
              border border-slate-300 rounded-lg shadow-sm text-sm text-slate-900 transition
              placeholder:text-slate-400
              focus:outline-none focus:border-slate-900 focus:ring-2 focus:ring-slate-900
            "
          >
        </div>

        <div class="mt-5">
          <label
            for="password"
            class="flex items-center gap-1.5 pl-1 text-sm font-medium text-slate-700"
          >
            {{ ux_icon('lucide:lock', { class: 'size-4 shrink-0' }) }}
            <span>{{ 'login.label.password'|trans }}</span>
          </label>
          <input
            type="password"
            id="password"
            name="_password"
            autocomplete="current-password"
            required
            class="
              block w-full mt-1.5 px-3 py-2.5
              border border-slate-300 rounded-lg shadow-sm text-sm text-slate-900 transition
              placeholder:text-slate-400
              focus:outline-none focus:border-slate-900 focus:ring-2 focus:ring-slate-900
            "
          >
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button
          type="submit"
          class="
            inline-flex items-center justify-center w-full mt-8 px-4 py-2.5
            bg-slate-900 rounded-lg shadow-sm text-sm font-semibold text-white transition
            hover:bg-slate-800
            focus:outline-none focus:ring-2 focus:ring-slate-900 focus:ring-offset-2
          "
        >
          {{ 'login.button.submit'|trans }}
        </button>
      </form>
    </div>
  </section>
{% endblock %}
