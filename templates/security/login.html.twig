{% extends 'layout/centered.html.twig' %}

{% block title %}{{ 'login.title'|trans }}{% endblock %}

{% block content %}
  <section
    class="
      overflow-hidden
      w-full max-w-md
      border border-slate-200
      rounded-xl shadow-sm
    "
  >
    <header
      class="
        flex items-center
        h-10 pl-4
        bg-white
        border-b border-slate-200
      "
    >
      <div
        class="
          inline-flex items-center gap-1
          text-lg
        "
      >
        {{ ux_icon(
          'lucide:package',
          { class: 'size-5 shrink-0' },
        ) }}
        <span>Stockflow</span>
      </div>
    </header>

    <div class="px-6 pt-3 pb-8">
      <h1
        class="
          flex items-center justify-center gap-2 mb-4
          text-2xl
        "
      >
        {{ ux_icon(
          'lucide:log-in',
          { class: 'size-6 shrink-0' },
        ) }}
        <span>{{ 'login.heading'|trans }}</span>
      </h1>

      {% if error %}
        <div
          role="alert"
          class="
            flex items-center gap-1 mb-4
            px-4 py-2
            bg-red-50
            border border-red-200
            rounded-lg
            text-sm text-red-700
          "
        >
          {{ ux_icon(
            'lucide:circle-alert',
            { class: 'size-4 shrink-0' },
          ) }}
          <span class="min-w-0">
            {{ error.messageKey|trans(error.messageData, 'security') }}
          </span>
        </div>
      {% endif %}

      <form
        method="post"
        action="{{ path('app_login') }}"
      >
        <p class="mb-4 text-sm text-slate-700">
          {{ 'login.instructions'|trans }}
        </p>

        <div class="mb-4">
          {% include 'components/form/text_input.html.twig' with {
            type: 'email',
            id: 'username',
            name: '_username',
            label: 'login.label.email'|trans,
            value: last_username,
            placeholder: 'login.placeholder.email'|trans,
            autocomplete: 'username',
            required: true,
            autofocus: true,
          } only %}
        </div>

        <div class="mb-8">
          {% include 'components/form/password_input.html.twig' with {
            id: 'password',
            name: '_password',
            label: 'login.label.password'|trans,
            showLabel: 'login.password.show'|trans,
            hideLabel: 'login.password.hide'|trans,
          } only %}
        </div>

        <input
          type="hidden"
          name="_csrf_token"
          value="{{ csrf_token('authenticate') }}"
        >

        {% include 'components/primary_button.html.twig' with {
          label: 'login.button.submit'|trans,
          fullWidth: true,
        } only %}
      </form>
    </div>
  </section>
{% endblock %}
